{
  "name": "teslacam-studio",
  "version": "2026.6.2",
  "description": "TeslaCam Studio is a local Electron viewer for Tesla dashcam multi-camera clips and embedded SEI telemetry.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/dashcam-mp4.js && node --check src/renderer/renderer.js",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "keywords": [
    "tesla",
    "dashcam",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0"
  },
  "build": {
    "appId": "com.sidecloudgroup.teslacamstudio",
    "productName": "TeslaCam Studio",
    "copyright": "Copyright 2026 TeslaCam Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "node_modules/ffmpeg-static/**/*",
      "dashcam.proto",
      "README.md",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "category": "AudioVideo",
      "target": [
        "AppImage"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "ffmpeg-static@5.3.0": true
  }
}
